# Environment
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_platform

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TOKEN_DB=1

# JWT — CHANGE THIS IN PRODUCTION
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# File Uploads
MAX_UPLOAD_SIZE_BYTES=10485760
UPLOAD_DIRECTORY=./uploads

# Logging
LOG_LEVEL=INFO

# Amazon Bedrock / Moonshot AI Kimi
# Create a Bedrock API key in AWS and keep it out of source control.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION_NAME=us-east-1
BEDROCK_MODEL_ID=moonshotai.kimi-k2.5
